namespace rerun.datatypes;

// ---

/// A point in 3D space used by [archetypes.Trail3D].
struct Trail3DPoint (
  "attr.rerun.state": "unstable",
  "attr.rust.derive": "Default, Copy, PartialEq, bytemuck::Pod, bytemuck::Zeroable",
  "attr.rust.repr": "C"
) {
  /// X coordinate.
  x: rerun.datatypes.Float32 (order: 100);

  /// Y coordinate.
  y: rerun.datatypes.Float32 (order: 200);

  /// Z coordinate.
  z: rerun.datatypes.Float32 (order: 300);
}
